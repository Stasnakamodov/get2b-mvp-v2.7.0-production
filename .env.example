# Database (PostgreSQL)
DATABASE_URL=postgresql://get2b:YOUR_DB_PASSWORD@postgres:5432/get2b
DB_PASSWORD=YOUR_DB_PASSWORD

# Auth (JWT)
JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS

# Storage
UPLOAD_DIR=/data/uploads

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_CHAT_BOT_TOKEN=your_telegram_chat_bot_token

# AI Services
BOTHUB_API_KEY=your_bothub_api_key
BOTHUB_API_TOKEN=your_bothub_api_token
ANTHROPIC_API_KEY=your_anthropic_api_key

# External APIs
YANDEX_VISION_API_KEY=your_yandex_vision_api_key
YANDEX_FOLDER_ID=your_yandex_folder_id
KONTUR_ENI_API_KEY=your_kontur_eni_api_key
SCRAPER_API_KEY=your_scraper_api_key
OTAPI_INSTANCE_KEY=your_otapi_instance_key

# App Configuration
NEXT_PUBLIC_BASE_URL=https://get2b.pro
NODE_ENV=production

# Cron secret for /api/cron/* endpoints (e.g. expire-listings).
# Generate with: openssl rand -hex 32
CRON_SECRET=
